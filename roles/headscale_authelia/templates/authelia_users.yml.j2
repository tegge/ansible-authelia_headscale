---
# Authelia Users Database
# Generated by Ansible - Manual edits will be overwritten

users:
{% for user in headscale_authelia_auth_users %}
  {{ user.username }}:
    displayname: "{{ user.displayname }}"
    password: "{{ user.password }}"
    email: "{{ user.email }}"
    groups:
{% for group in user.groups %}
      - {{ group }}
{% endfor %}
{% endfor %}
