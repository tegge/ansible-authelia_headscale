services:
{% if headscale_authelia_deploy_traefik | default(false) | bool %}
  #============================================================================
  # TRAEFIK REVERSE PROXY
  #============================================================================
  traefik:
    image: {{ headscale_authelia_traefik_image }}
    container_name: {{ headscale_authelia_traefik_container_name }}
    restart: unless-stopped
    networks:
      - {{ headscale_authelia_traefik_network }}
    ports:
      - "{{ headscale_authelia_traefik_http_port }}:80"
      - "{{ headscale_authelia_traefik_https_port }}:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ headscale_authelia_volumes_dir }}/traefik/acme:/acme
    command:
      # API and Dashboard
      - "--api.insecure=false"
{% if headscale_authelia_traefik_dashboard_enabled | default(false) | bool %}
      - "--api.dashboard=true"
{% else %}
      - "--api.dashboard=false"
{% endif %}
      # Docker provider
      - "--providers.docker=true"
      - "--providers.docker.exposedbydefault=false"
      - "--providers.docker.network={{ headscale_authelia_traefik_network }}"
      # Entrypoints
      - "--entrypoints.web.address=:80"
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
      - "--entrypoints.websecure.address=:443"
      # Let's Encrypt ACME
      - "--certificatesresolvers.{{ headscale_authelia_traefik_certresolver }}.acme.email={{ headscale_authelia_traefik_acme_email }}"
      - "--certificatesresolvers.{{ headscale_authelia_traefik_certresolver }}.acme.storage=/acme/acme.json"
      - "--certificatesresolvers.{{ headscale_authelia_traefik_certresolver }}.acme.httpchallenge.entrypoint=web"
{% if headscale_authelia_traefik_acme_staging | default(false) | bool %}
      - "--certificatesresolvers.{{ headscale_authelia_traefik_certresolver }}.acme.caserver=https://acme-staging-v02.api.letsencrypt.org/directory"
{% endif %}
      # Logging
      - "--log.level={{ headscale_authelia_traefik_log_level | default('INFO') }}"
    labels:
      - "traefik.enable=true"
{% if headscale_authelia_traefik_dashboard_enabled | default(false) | bool %}
      - "traefik.http.routers.traefik-dashboard.rule=Host(`traefik.{{ headscale_authelia_hostname | regex_replace('^[^.]+\\.', '') }}`)"
      - "traefik.http.routers.traefik-dashboard.entrypoints=websecure"
      - "traefik.http.routers.traefik-dashboard.tls=true"
      - "traefik.http.routers.traefik-dashboard.tls.certresolver={{ headscale_authelia_traefik_certresolver }}"
      - "traefik.http.routers.traefik-dashboard.service=api@internal"
{% endif %}
    healthcheck:
      test: ["CMD", "traefik", "healthcheck"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s

{% endif %}
  #============================================================================
  # AUTHELIA
  #============================================================================
  authelia:
    image: authelia/authelia:latest
    container_name: authelia_{{ headscale_authelia_stack_name }}
    user: "{{ headscale_authelia_service_uid }}:{{ headscale_authelia_service_gid }}"
    networks:
      - internal
      - {{ headscale_authelia_traefik_network }}
    volumes:
      - "{{ headscale_authelia_volumes_dir }}/authelia:/config"
    environment:
      - AUTHELIA_JWT_SECRET={{ headscale_authelia_jwt_secret }}
      - AUTHELIA_SESSION_SECRET={{ headscale_authelia_session_secret }}
      - AUTHELIA_STORAGE_ENCRYPTION_KEY={{ headscale_authelia_storage_encryption_key }}
    expose:
      - "9091"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:9091/api/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ headscale_authelia_traefik_network }}"
      - "traefik.http.routers.authelia.rule=Host(`{{ headscale_authelia_auth_hostname }}`)"
      - "traefik.http.routers.authelia.entrypoints=websecure"
      - "traefik.http.routers.authelia.tls=true"
{% if headscale_authelia_traefik_certresolver is defined and headscale_authelia_traefik_certresolver | length > 0 %}
      - "traefik.http.routers.authelia.tls.certresolver={{ headscale_authelia_traefik_certresolver }}"
{% endif %}
      - "traefik.http.services.authelia.loadbalancer.server.port=9091"

  headscale:
    image: headscale/headscale:latest
    container_name: headscale_{{ headscale_authelia_stack_name }}
    user: "{{ headscale_authelia_service_uid }}:{{ headscale_authelia_service_gid }}"
    networks:
      - internal
      - {{ headscale_authelia_traefik_network }}
{% if headscale_authelia_traefik_container_ip is defined %}
    extra_hosts:
      - "{{ headscale_authelia_auth_hostname }}:{{ headscale_authelia_traefik_container_ip }}"
      - "{{ headscale_authelia_hostname }}:{{ headscale_authelia_traefik_container_ip }}"
{% endif %}
    depends_on:
      authelia:
        condition: service_healthy
    volumes:
      - {{ headscale_authelia_volumes_dir }}/headscale/config:/etc/headscale
      - {{ headscale_authelia_volumes_dir }}/headscale/lib:/var/lib/headscale
      - {{ headscale_authelia_volumes_dir }}/headscale/run:/var/run/headscale
{% if headscale_authelia_enable_step_ca_trust | default(false) | bool %}
      - {{ headscale_authelia_certs_dir }}/step-ca-root.crt:/usr/local/share/ca-certificates/step-ca-root.crt:ro
{% endif %}
    command: serve
    expose:
      - "{{ headscale_authelia_grpc_port }}"
    ports:
      - "127.0.0.1:8080:{{ headscale_authelia_http_port }}"
      - "3478:3478/udp"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "headscale", "nodes", "list"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network={{ headscale_authelia_traefik_network }}"
      - "traefik.http.routers.headscale.rule=Host(`{{ headscale_authelia_hostname }}`)"
      - "traefik.http.routers.headscale.entrypoints=websecure"
      - "traefik.http.routers.headscale.tls=true"
{% if headscale_authelia_traefik_certresolver is defined and headscale_authelia_traefik_certresolver | length > 0 %}
      - "traefik.http.routers.headscale.tls.certresolver={{ headscale_authelia_traefik_certresolver }}"
{% endif %}
      - "traefik.http.services.headscale.loadbalancer.server.port={{ headscale_authelia_http_port }}"

  tailscale-router:
    image: tailscale/tailscale:latest
    container_name: tailscale-router_{{ headscale_authelia_stack_name }}
    hostname: docker-subnet-router
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - SYS_MODULE
    entrypoint: ["/usr/local/bin/tailscale-entrypoint.sh"]
    volumes:
      - {{ headscale_authelia_volumes_dir }}/tailscale:/var/lib/tailscale
      - {{ headscale_authelia_base_data_dir }}/{{ headscale_authelia_stack_name }}/tailscale-entrypoint.sh:/usr/local/bin/tailscale-entrypoint.sh:ro
    environment:
      - TS_STATE_DIR=/var/lib/tailscale
      - TS_AUTHKEY=${TS_AUTHKEY:-}
      - TS_AUTH_ONCE=true
      - TS_ROUTES={{ headscale_authelia_tailscale_routes | join(',') }}
      - TS_ACCEPT_ROUTES=true
      - TS_HOSTNAME=docker-subnet-router
      - TS_EXTRA_ARGS=--login-server=http://127.0.0.1:8080
    depends_on:
      headscale:
        condition: service_healthy

networks:
  internal:
    name: {{ headscale_authelia_stack_name }}_net
    driver: bridge

  {{ headscale_authelia_traefik_network }}:
{% if headscale_authelia_deploy_traefik | default(false) | bool %}
    name: {{ headscale_authelia_traefik_network }}
    driver: bridge
{% else %}
    external: true
{% endif %}
